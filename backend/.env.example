# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Required for session signing (use a random 32+ char string in production)
SESSION_SECRET=your-random-session-secret-here

# Required for admin site login
ADMIN_SECRET=your-strong-admin-password-here

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# Cloudflare R2 storage
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY=your-s3-access-key-id
R2_SECRET_KEY=your-s3-secret-access-key
R2_BUCKET_NAME=epubanything
R2_PUBLIC_URL=

STORAGE=local
BASE_URL=http://localhost:8000
